{
	"name": "ai-usage-tracker",
	"version": "0.1.1",
	"description": "Chrome extension that tracks Claude and Codex usage limits (session and weekly).",
	"license": "MIT",
	"author": "",
	"repository": {
		"type": "git",
		"url": ""
	},
	"keywords": [
		"chrome-extension",
		"mv3",
		"react",
		"typescript",
		"vite",
		"claude",
		"codex",
		"usage-tracker"
	],
	"engines": {
		"node": ">=20.0.0"
	},
	"type": "module",
	"scripts": {
		"dev": "vite build --watch --mode development",
		"typecheck": "tsc --noEmit",
		"test": "node --test tests/",
		"build": "npm run typecheck && vite build",
		"release": "npm test && npm run build && node scripts/release.js",
		"lint": "eslint src",
		"lint:fix": "eslint src --fix",
		"format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
		"format:check": "prettier --check \"src/**/*.{ts,tsx,css}\""
	},
	"dependencies": {
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-shadow": "^20.6.0"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.2",
		"@types/chrome": "^0.0.315",
		"@types/dom-chromium-ai": "^0.0.14",
		"@types/node": "^25.2.3",
		"@types/react": "^19.2.13",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^4.7.0",
		"autoprefixer": "^10.4.24",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-react-hooks": "^7.0.1",
		"postcss": "^8.5.6",
		"prettier": "^3.8.1",
		"tailwindcss": "^3.4.19",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.55.0",
		"vite": "^5.4.21",
		"vite-plugin-web-extension": "^4.5.0"
	}
}
